############
# REQUIRED #
############

ENVIRONMENT=dev
API_TITLE="AI Voice Cold Calling Agent"
API_DESCRIPTION="AI voice cold-calling agent: Twilio + Deepgram STT + OpenAI + ElevenLabs TTS"
API_VERSION="0.1.0"

# SQLite for local dev; use postgresql+asyncpg://user:pass@host/db in prod
DATABASE_URL=sqlite+aiosqlite:///./database.db
REDIS_URL=redis://localhost:6379/0

# https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# https://platform.openai.com/account/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# https://elevenlabs.io (click on your avatar then 'Profile')
ELEVENLABS_API_KEY=
ELEVENLABS_DEFAULT_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_flash_v2_5

# https://console.deepgram.com
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-2-phonecall

# Public HTTPS base URL Twilio can reach (an ngrok URL in dev)
SERVER_ADDRESS=

# JWT - generate a real secret, e.g. `openssl rand -hex 32`
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=43200

MAX_CONCURRENT_CALLS=5
CORS_ALLOW_ORIGINS=[]
